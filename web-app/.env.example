# web-app environment variables
# Copy to .env and adjust as needed.

# Vite dev server port (set automatically per worktree — do not edit manually)
PORT=5173

# Backend API URL — the only VITE_ env var needed.
# All other config (Supabase URL, keys, PostHog, etc.) is fetched from the backend's /config endpoint.
VITE_API_URL=http://localhost:8000
