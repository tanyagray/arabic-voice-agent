{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "web-app",
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "admin-app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "admin-app",
      "port": 5174,
      "autoPort": true
    },
    {
      "name": "web-api",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "uvicorn", "main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "web-api",
      "port": 8000
    }
  ]
}
