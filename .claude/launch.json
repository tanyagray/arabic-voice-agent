{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-app",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", ". ~/.nvm/nvm.sh 2>/dev/null; npm run dev"],
      "cwd": "web-app",
      "port": 5173
    },
    {
      "name": "web-app-fake-mic",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", ". ~/.nvm/nvm.sh 2>/dev/null; VITE_FAKE_MIC=1 npm run dev"],
      "cwd": "web-app",
      "port": 5173
    },
    {
      "name": "storybook",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", ". ~/.nvm/nvm.sh 2>/dev/null; npm run storybook -- --no-open"],
      "cwd": "web-app",
      "port": 6006
    },
    {
      "name": "admin-app",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", ". ~/.nvm/nvm.sh 2>/dev/null; npm run dev"],
      "cwd": "admin-app",
      "port": 5174
    },
    {
      "name": "web-api",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "export PATH=/opt/homebrew/bin:$PATH; uv run uvicorn main:app --reload --host 0.0.0.0 --port 8000"],
      "cwd": "web-api",
      "port": 8000
    }
  ]
}
