# Root-level patterns applicable to entire project

# Dependencies
node_modules/

# Environment variables — .env files are local-only, never committed.
# .env.example files are committed as templates for each service.
.env
.env.local
.env.*.local

# dotenvx: encrypted env files (supabase) are safe to commit; keys file is not.
supabase/.env.keys

# IDEs and editors
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log

# Temporary files
*.tmp
*.temp

# Task runner
.task/

# Terraform
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
terraform.tfvars
*.auto.tfvars
