# Supabase Configuration
# Find these in your Supabase project settings under API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your_secret_key_here
SUPABASE_PUBLISHABLE_KEY=sb_publishable_

# AI Services API Keys
OPENAI_API_KEY=
GOOGLE_GENAI_API_KEY=

# Pipecat Services
DEEPGRAM_API_KEY=
ELEVEN_API_KEY=

# Legacy Services (optional - for non-pipecat endpoints)
SONIOX_API_KEY=
WEBHOOK_BASE_URL=http://localhost:8000

# BrainTrust Telemetry (optional - enables LLM request logging)
# See https://www.braintrust.dev/ for setup instructions
BRAINTRUST_API_KEY=
BRAINTRUST_PROJECT=mishmish

# Server Configuration (optional)
HOST=0.0.0.0
PORT=8000
