# web-api environment variables
# Copy to .env and adjust as needed.
# Run `scripts/pull-secrets.sh` to populate secrets from AWS Secrets Manager.

# --- Secrets (populated by pull-secrets.sh from AWS Secrets Manager) ---

# Supabase — local defaults work out of the box with `supabase start`
SUPABASE_URL=http://localhost:54321
SUPABASE_SECRET_KEY=
SUPABASE_PUBLISHABLE_KEY=

# AI / Voice pipeline
OPENAI_API_KEY=
ELEVEN_API_KEY=
SONIOX_API_KEY=
GEMINI_API_KEY=

# --- Local config (not in Secrets Manager) ---

# Webhook base URL for Soniox callbacks (use ngrok/cloudflare tunnel for local dev)
WEBHOOK_BASE_URL=http://localhost:8000

# PostHog Analytics
POSTHOG_API_KEY=phc_1ZBbhKOZcsCo52DvnYzl1ie38hPfPaLrUCxdymVhDIQ
POSTHOG_HOST=https://us.i.posthog.com

# Server
HOST=0.0.0.0
PORT=8000
