# Supabase local environment variables
# All env() references in config.toml must be defined here.
# Copy to .env and adjust as needed.

# Auth
SITE_URL=http://localhost:5173

# Email — disabled locally (emails go to Inbucket)
RESEND_ENABLED=false
RESEND_API_KEY=

# Google OAuth — leave blank for local dev
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
